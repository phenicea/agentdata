# Keep the build context lean and — critically — keep secrets OUT of the image.
# (CLAUDE.md §14: no .env / keys ever in the image or repo.)

# Secrets — never copy a real env / key into the image.
.env
.env.*
*.key
secrets/

# VCS / CI
.git
.gitignore
.github

# Python build/cache cruft
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
.venv/
venv/

# Tests are not needed in the runtime image
tests/

# Local tooling / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db
