# AgentData — environment. Copy to .env and adjust. NEVER commit a real .env.

# --- Network mode -----------------------------------------------------------
# testnet (default) = Base Sepolia, prices forced to $0, no real USDC.
# mainnet = real prices + real USDC. Flipping this is an ESCALATED human decision
#           (CLAUDE.md §0/§14). Do not set to mainnet without sign-off + review.
NETWORK_MODE=testnet

# Separate, explicit authorization to actually run on mainnet. The app REFUSES to
# start when NETWORK_MODE=mainnet unless this is true (ADR-001 §4 guardrail), so
# mainnet can never be reached by accident. Setting it true is a reviewed human
# escalation after auditing the funds-touching code — never flip it casually.
ALLOW_MAINNET=false

# --- Pool source ------------------------------------------------------------
# fixture (default) = deterministic local pools, no network, no secrets.
# onchain = read Base via RPC (requires BASE_RPC_URL + a verified pool registry).
POOL_SOURCE=fixture

# --- On-chain reads (only needed when POOL_SOURCE=onchain) -------------------
# Public RPC is fine for dev/backfill. A PAID RPC at volume is a real expense =>
# ESCALATE to human before committing to one (affects the $0.008 price floor).
BASE_RPC_URL=

# Pegged tokens for depeg signal, comma-separated SYMBOL:REF (e.g. USDC:1.0,USDT:1.0)
PEGGED_TOKENS=

# --- Payment (Phase 2, x402) ------------------------------------------------
# OPT-IN switch for the x402 payment middleware. Default false => middleware is
# NOT mounted, the FastAPI app is untouched, and the Phase 1 tests keep passing.
# Set to true to charge per call. See docs/x402-integration.md.
X402_ENABLED=false

# Receiving wallet for USDC. ONLY the PUBLIC address goes here. The wallet PRIVATE
# KEY must live in a secret manager / runtime env var, NEVER in the repo or a
# committed .env (CLAUDE.md §14). Used as `pay_to` in the 402 payment requirements.
PAY_TO_ADDRESS=

# x402 facilitator that verifies (/verify) and settles (/settle) payments.
# Leave empty to use the default for the current NETWORK_MODE:
#   testnet => https://x402.org/facilitator  (free, Base Sepolia)
#   mainnet => no default; set deliberately at the mainnet escalation (human decision).
# Override here only if you run your own facilitator.
FACILITATOR_URL=
